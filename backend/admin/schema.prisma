// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource postgresql {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Player {
  id            String    @id @default(cuid())
  nickname      String    @unique @default("")
  pinHash       String    @default("")
  joinedAt      DateTime? @default(now()) @map("joinedAt")
  lastLoginAt   DateTime? @default(now()) @map("lastLoginAt")
  lastPositionX Float?    @default(0) @map("lastPositionX")
  lastPositionY Float?    @default(0) @map("lastPositionY")
  lastPositionZ Float?    @default(0) @map("lastPositionZ")

  @@map("players")
}

model Guestbook {
  id        String    @id @default(cuid())
  authorId  String    @default("")
  content   String    @default("")
  createdAt DateTime? @default(now()) @map("createdAt")
  updatedAt DateTime? @default(now()) @map("updatedAt")

  @@map("guestbook")
}
